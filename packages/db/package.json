{
  "name": "@investigation-ai/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Drizzle schema, migrations, and database client.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "drizzle",
    "database-config.mjs",
    "drizzle.config.mjs",
    "migrate.mjs",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc --watch --pretty",
    "build": "rimraf dist && tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.mjs",
    "db:migrate": "node ./migrate.mjs",
    "db:check": "drizzle-kit check --config=drizzle.config.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.43.1",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.1"
  }
}
